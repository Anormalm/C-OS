COS_APP_ENV=dev
COS_LOG_LEVEL=INFO
COS_GRAPH_BACKEND=inmemory
COS_VECTOR_BACKEND=inmemory

# For Neo4j backend
COS_NEO4J_URI=bolt://localhost:7687
COS_NEO4J_USER=neo4j
COS_NEO4J_PASSWORD=password

# Optional feedback persistence path
# COS_FEEDBACK_LOG_PATH=.cos_data/feedback.jsonl

# Optional action-completion persistence path
# COS_ACTION_LOG_PATH=.cos_data/actions.jsonl

# Optional LLM provider (DeepSeek v4 Pro)
# COS_LLM_PROVIDER=deepseek
# COS_LLM_API_KEY=your_deepseek_api_key
# COS_LLM_MODEL=deepseek-v4-pro
# COS_LLM_BASE_URL=https://api.deepseek.com
# COS_LLM_TIMEOUT_SECONDS=20
# COS_LLM_REASONING_EFFORT=high
